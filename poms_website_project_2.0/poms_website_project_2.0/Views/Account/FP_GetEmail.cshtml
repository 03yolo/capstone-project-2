@model poms_website_project_2._0.Models.UserModel

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}


<head>
    <link href='https://fonts.googleapis.com/css?family=Inter' rel='stylesheet'>
    <link href='https://fonts.googleapis.com/css?family=Raleway' rel='stylesheet'>
    <style>
        body {
            font-family: 'Inter';
            background-color: #F5F5F5;
            overflow: hidden;
            margin: 0;
        }

        .header {
            background-color: #3E0F0F;
            color: #F5F5F5;
            height: 70px;
            padding: 0.5rem 2rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .header-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header-row .left {
            font-size: 1.2rem;
            font-family: 'Raleway';
            font-weight: bold;
        }

        .header-row .right {
            font-size: 1.2rem;
        }

        .header-row a {
            color: #F5F5F5;
            text-decoration: none;
        }

        .mainbody {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            line-height: 0.2;
            min-height: calc(100vh - 70px);
        }

        h2 {
            font-family: 'Raleway';
            color: #811515;
        }

        p {
            font-size: 1.1rem;
        }

        .enteremail {
            border-radius: 10px;
            border: 1px solid black;
            background-color: #D9D8D8;
            padding: 20px;
            margin-top: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px;
            height: 150px;
            margin-bottom: 20px;
        }

        input {
            width: 350px;
            height: 20px;
            border: 1px solid black;
            border-radius: 5px;
            font-family: 'Inter';
            padding: 10px;
            font-size: 1.1rem;
        }

        .fake-button {
            background-color: #811515;
            color: white;
            padding: 1.5rem;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            text-align: center;
            user-select: none;
            transition: background-color 0.2s ease;
            font-size: 1.05rem;
            width: 200px;
            justify-content: center;
            align-items: center;
            margin-top: 10px;
        }

        .fake-button:hover {
            background-color: #5A1A1A;
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="header-row">
            <div class="left">Prudencia D. Fule Memorial National High School</div>
            <div class="right">Already remembered your password?</div>
        </div>
        <div class="header-row">
            <div class="left">Online Management System</div>
            <div class="right"><a href="#"><b><u>Click here to login!</u></b></a></div>
        </div>
    </header>

    <div class="mainbody">
        <form>
            <h2>Forgot your password?</h2>
            <p>Enter your registered email address, and we’ll send further instructions there.</p>
            <div class="enteremail">
                <input asp-for="Email" type="text">
                <p class="fake-button">Send Email</p>
            </div>
            <p><i>If your email is registered, the instructions will be sent there. Thank you!</i></p>
        </form>
    </div>
</body>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}